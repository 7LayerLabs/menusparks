// MenuSparks Database Schema
// PostgreSQL with Prisma ORM + NextAuth.js

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// NextAuth.js Models
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Admin
  isAdmin Boolean @default(false)

  // Stripe
  stripeCustomerId String? @unique

  // Credit / Usage Tracking
  generationsUsed        Int      @default(0)
  generationsThisMonth   Int      @default(0)
  generationsResetAt     DateTime @default(now())

  // Relations
  accounts           Account[]
  sessions           Session[]
  restaurants        Restaurant[]
  subscriptions      Subscription[]
  payments           Payment[]
  recipeGenerations  RecipeGeneration[]
  restaurantProfile  UserRestaurantProfile?
  socialSettings     UserSocialSettings?
  savedRecipes       SavedRecipe[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// Restaurant & Business Models
// ============================================

model Restaurant {
  id          String   @id @default(cuid())
  userId      String
  name        String
  type        String // fast_casual, fine_dining, food_truck, etc.
  cuisineStyle String[] // italian, mexican, american, etc.
  description String?

  // Location
  city        String
  state       String
  zipCode     String?

  // Brand & Style
  priceTier   String   @default("moderate") // budget, moderate, upscale
  brandVoice  String?  @db.Text
  menuContext String?  @db.Text // uploaded menu parsed as text

  // Kitchen Info
  equipment   String[] // oven, grill, fryer, etc.

  // Preferences
  dietaryPreferences String[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
  recipes       Recipe[]

  @@map("restaurants")
}

model Subscription {
  id           String   @id @default(cuid())
  userId       String
  restaurantId String?

  tier         String // quick_byte (20/mo), chefs_choice (40/mo)
  monthlyGenerationLimit Int @default(20)
  status       String   @default("active") // active, paused, cancelled

  // Delivery Schedule
  deliveryDay  String   @default("monday")
  deliveryTime String   @default("08:00")

  // Stripe
  stripeSubscriptionId String? @unique
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  deliveries Delivery[]
  payments   Payment[]

  @@map("subscriptions")
}

model Delivery {
  id             String   @id @default(cuid())
  subscriptionId String

  scheduledDate  DateTime
  deliveredAt    DateTime?
  status         String   @default("scheduled") // scheduled, generating, delivered, failed

  recipeIds      String[] // array of recipe IDs
  emailSent      Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  recipes      Recipe[]

  @@map("deliveries")
}

model Recipe {
  id             String   @id @default(cuid())
  restaurantId   String
  deliveryId     String?

  // Recipe Details
  name           String
  mealType       String // appetizer, entree, dessert, etc.
  menuDescription String  @db.Text
  yield          String // e.g., "12 portions"

  // Recipe Content (stored as JSON)
  ingredients    Json
  miseEnPlace    Json
  preServicePrep Json
  serviceInstructions Json
  chefsNotes     String?  @db.Text

  // Generation Metadata
  style          String // creative, classic, hybrid
  complexity     String // basic, intermediate, chef_level

  // Social Media (for Chef's Choice tier)
  socialMediaPost String? @db.Text

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  delivery   Delivery?  @relation(fields: [deliveryId], references: [id], onDelete: SetNull)

  @@map("recipes")
}

model Payment {
  id                      String   @id @default(cuid())
  userId                  String
  subscriptionId          String

  stripePaymentIntentId   String   @unique
  amount                  Decimal  @db.Decimal(10, 2)
  status                  String // succeeded, failed, pending

  billingDate             DateTime
  createdAt               DateTime @default(now())

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ============================================
// Credit-Based Usage Tracking
// ============================================

model RecipeGeneration {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeCount Int
  mealTypes   String
  recipeStyle String
  complexity  String
  theme       String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("recipe_generations")
}

// ============================================
// User Restaurant Profile & Social Settings
// ============================================

model UserRestaurantProfile {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantName          String   @default("")
  restaurantType          String   @default("")
  cuisineStyle            String   @default("")
  location                String   @default("")
  phone                   String   @default("")
  description             String   @default("")
  defaultRecipeStyle      String   @default("classic")
  defaultComplexity       String   @default("basic")
  defaultDecade           String   @default("")
  defaultTheme            String   @default("")
  defaultRestaurantStyles String   @default("[]")
  updatedAt               DateTime @updatedAt

  @@map("user_restaurant_profiles")
}

model UserSocialSettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tone          String   @default("casual")
  brandHashtags String   @default("")
  ctaTemplate   String   @default("")
  alwaysInclude String   @default("")
  alwaysExclude String   @default("")
  platforms     String   @default("Instagram,Facebook")
  updatedAt     DateTime @updatedAt

  @@map("user_social_settings")
}

model SavedRecipe {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipeName   String
  mealType     String
  description  String   @db.Text
  yield        String
  ingredients  String   @db.Text
  prep         String   @db.Text
  bulkPrep     String   @db.Text
  instructions String   @db.Text
  chefNotes    String?  @db.Text
  socialPost   String?  @db.Text
  tags         String   @default("[]") // JSON array of tags e.g. ["Spring","Holiday"]
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("saved_recipes")
}

// ============================================
// Newsletter Models (Future Phase)
// ============================================

model Newsletter {
  id            String   @id @default(cuid())
  type          String // industry, regional_custom
  content       Json
  publishedAt   DateTime
  sentCount     Int      @default(0)

  createdAt     DateTime @default(now())

  @@map("newsletters")
}
